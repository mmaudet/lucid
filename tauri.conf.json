{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lucid",
  "version": "0.1.0",
  "identifier": "com.linagora.lucid",
  "build": {
    "frontendDist": "ui/dist",
    "beforeBuildCommand": "npm --prefix ui run build",
    "beforeDevCommand": "npm --prefix ui run dev",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": ["app", "dmg"],
    "category": "Productivity"
  }
}
